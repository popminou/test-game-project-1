{
  "name": "test-project",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"yarn workspace @test-project/server dev\" \"yarn workspace @test-project/client dev\"",
    "build": "yarn workspace @test-project/iso build && yarn workspace @test-project/client build && yarn workspace @test-project/server build",
    "start": "yarn workspace @test-project/server start",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'packages/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,json,css}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx,json,css}'",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
